# Copy this file to .env and fill in your values
# .env is gitignored — never commit it

# GitHub Personal Access Token (repo scope)
# Target repo: techjalebi/dora-demo-app
GITHUB_TOKEN=

# Jira Cloud credentials
JIRA_BASE_URL=https://yoursite.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=

# Jira project (do not change unless you renamed it)
JIRA_PROJECT_KEY=DORA

# Simulation parameters (adjust as needed)
SIM_START_DATE=2025-09-01
SIM_END_DATE=2026-03-01
SIM_FAILURE_RATE=0.15
GITHUB_DEMO_REPO=techjalebi/dora-demo-app
